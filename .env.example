# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit real secrets.

# --- LLM summarization (recommended) ---
# OpenAI API key used by the LLM summarizer. If unset, the digest falls back
# to the local rule-based summarizer and says so in the report.
OPENAI_API_KEY=

# --- Email sending (optional; dry-run works without these) ---
# From address shown on the digest email.
DIGEST_EMAIL_FROM=
# SMTP login. For Gmail use your address plus an App Password
# (https://myaccount.google.com/apppasswords), not your normal password.
DIGEST_SMTP_USERNAME=
DIGEST_SMTP_PASSWORD=
